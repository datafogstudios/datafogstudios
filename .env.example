# Environment Variables

## Frontend
VITE_API_URL=http://localhost:5000
VITE_SOCKET_IO_URL=http://localhost:5001

## Backend
NODE_ENV=development
PORT=5000
JWT_SECRET=your_jwt_secret_key_here_change_in_production

## Database
DATABASE_URL=postgresql://user:password@localhost:5432/datafogstudios
MONGODB_URI=mongodb://localhost:27017/datafogstudios
REDIS_URL=redis://localhost:6379

## Stripe
STRIPE_PUBLIC_KEY=pk_test_51234567890
STRIPE_SECRET_KEY=sk_test_1234567890

## Coinbase Commerce
COINBASE_API_KEY=your_coinbase_api_key

## Google AdSense
GOOGLE_ADSENSE_ID=ca-pub-1234567890

## Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_password

## AWS (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=datafogstudios-files

## Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn

## Founder Info
FOUNDER_NAME=Hassan S. Mohamed
FOUNDER_EMAIL=hassan@datafogstudios.com
